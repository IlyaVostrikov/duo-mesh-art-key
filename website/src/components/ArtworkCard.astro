---
export interface Props {
  id: string
  title: string
  images: string[]
  category: string
  price: string | null
  currency: string
  artistName?: string | null
}

const { id, title, images, category, price, currency, artistName } = Astro.props
const img = images[0] ?? '/placeholder-art.svg'
const priceDisplay = price ? `${Number(price).toLocaleString()} ${currency}` : null
---

<a href={`/artworks/${id}`} class="card">
  <div class="card-image">
    <img src={img} alt={title} loading="lazy" />
    <span class="category-tag">{category}</span>
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    {artistName && <p class="card-artist">{artistName}</p>}
    {priceDisplay && <p class="card-price">{priceDisplay}</p>}
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    color: var(--text);
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .card-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #1a1a20;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .category-tag {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    background: rgba(0,0,0,0.7);
    color: var(--text-secondary);
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .card-body { padding: 1rem; }
  .card-title { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .card-artist { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem; }
  .card-price { font-size: 0.95rem; font-weight: 600; color: var(--gold); }
</style>
